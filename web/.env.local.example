# Copy to .env.local and adjust. Restart `npm run dev` after changes.

# FastAPI MF FAQ server (python -m runtime.phase_9_api), default port 8765
NEXT_PUBLIC_API_URL=http://127.0.0.1:8765

# For Railway / production, set this to your deployed backend URL:
# NEXT_PUBLIC_API_URL=https://your-backend-service.railway.app
