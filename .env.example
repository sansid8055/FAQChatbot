# Copy this file to `.env` in the repository root and fill in values.
#   cp .env.example .env
# The file `.env` is gitignored. Ingest CLIs load it automatically via python-dotenv.

# =============================================================================
# Chroma — phase 4.3 index + phase 5 retrieval (on-disk PersistentClient only)
# =============================================================================
# Collection and SQLite-backed persist directory (defaults shown).
# INGEST_CHROMA_COLLECTION=mf_faq_chunks
# INGEST_CHROMA_DIR=data/chroma
# INGEST_CHROMA_UPSERT_BATCH=64

# =============================================================================
# Optional — ingest tuning (uncomment if needed)
# =============================================================================
# Custom User-Agent for scraping (also available as GitHub secret INGEST_USER_AGENT)
# INGEST_USER_AGENT=

# INGEST_RATE_LIMIT_SECONDS=1.5
# INGEST_REPO_ROOT=

# Hugging Face cache for embedding models
# HF_HOME=

# =============================================================================
# Groq — phase 6 generation (rag-architecture.md §6)
# =============================================================================
GROQ_API_KEY=

# Optional (see https://console.groq.com/docs/models )
# GROQ_MODEL=llama-3.1-8b-instant
# GROQ_TEMPERATURE=0.2

# =============================================================================
# Phase 7 — educational refusal link (rag-architecture.md §7.1)
# =============================================================================
# EDUCATIONAL_URL=https://www.amfiindia.in/investor-corner/investor-education

# =============================================================================
# Phase 8 — threads / multi-turn (rag-architecture.md §8)
# =============================================================================
# Thread store: memory (default, no disk, lost on restart) or sqlite (durable)
# THREAD_BACKEND=memory
# SQLite path when THREAD_BACKEND=sqlite (default: data/threads/threads.sqlite3)
# THREAD_DB_PATH=
# Last-N turns for context window helpers (default 5)
# THREAD_MAX_TURNS=5
# Prior user utterances merged into retrieval query when follow-up detected (default 2)
# THREAD_EXPAND_PRIOR_USERS=2

# =============================================================================
# Phase 9 — HTTP API (rag-architecture.md §9)
# =============================================================================
# API_HOST=127.0.0.1
# PORT=8765
# RUNTIME_API_DEBUG=0
# Optional Bearer for POST /admin/reindex (returns 501 stub when valid)
# ADMIN_REINDEX_SECRET=
#
# Next.js UI (web/) uses its own web/.env.local — see web/.env.local.example
